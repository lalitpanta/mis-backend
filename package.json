{
  "name": "school-management-backend",
  "version": "1.0.0",
  "description": "Multi-tenant school management system backend",
  "main": "src/server/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server/server.js",
    "dev": "nodemon src/server/server.js",
    "seed": "node seedDb.js",
    "migrate": "npx db-migrate up",
    "migrate:down": "npx db-migrate down",
    "update-tenant-schemas": "node updateTenantSchemas.js",
    "fix-tenant-modules": "node fixTenantModules.js"
