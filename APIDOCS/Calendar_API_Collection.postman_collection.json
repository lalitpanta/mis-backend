  "item": [
    {
      "name": "Calendar API",
      "description": "Calendar viewing endpoints for different date formats (AD/BS)",
      "item": [
        {
          "name": "Get Month Calendar (Linear)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/month?year=2025&month=5&date_format=AD",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "month"],
              "query": [
                {
                  "key": "year",
                  "value": "2025",
                  "description": "Year (e.g., 2025)"
                },
                {
                  "key": "month",
                  "value": "5",
                  "description": "Month (1-12)"
                },
                {
                  "key": "date_format",
                  "value": "AD",
                  "description": "Date format: AD or BS (default: AD)"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month in linear (flat list) format"
          }
        },
        {
          "name": "Get Month Calendar (By Weeks)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/month/weeks?year=2025&month=5&date_format=AD",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "month", "weeks"],
              "query": [
                {
                  "key": "year",
                  "value": "2025"
                },
                {
                  "key": "month",
                  "value": "5"
                },
                {
                  "key": "date_format",
                  "value": "AD"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month organized by weeks"
          }
        },
        {
          "name": "Get BS Month Calendar (Linear)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/bs/month?year=2081&month=2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "bs", "month"],
              "query": [
                {
                  "key": "year",
                  "value": "2081",
                  "description": "Year in BS"
                },
                {
                  "key": "month",
                  "value": "2",
                  "description": "Month (1-12)"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month in Bikram Sambat date system (linear format)"
          }
        },
        {
          "name": "Get BS Month Calendar (By Weeks)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/bs/weeks?year=2081&month=2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "bs", "weeks"],
              "query": [
                {
                  "key": "year",
                  "value": "2081"
                },
                {
                  "key": "month",
                  "value": "2"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month in Bikram Sambat format (organized by weeks)"
          }
        },
        {
          "name": "Get AD Month Calendar (Linear)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/ad/month?year=2025&month=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "ad", "month"],
              "query": [
                {
                  "key": "year",
                  "value": "2025"
                },
                {
                  "key": "month",
                  "value": "5"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month in Anno Domini date system (linear format)"
          }
        },
        {
          "name": "Get AD Month Calendar (By Weeks)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar/ad/weeks?year=2025&month=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar", "ad", "weeks"],
              "query": [
                {
                  "key": "year",
                  "value": "2025"
                },
                {
                  "key": "month",
                  "value": "5"
                }
              ]
            },
            "description": "Retrieves calendar for a specific month in Anno Domini format (organized by weeks)"
          }
        }
      ]
