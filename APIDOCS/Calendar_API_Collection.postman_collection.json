    {
      "name": "Calendar Days API",
      "description": "Endpoints for managing individual calendar days and assigning day types",
      "item": [
        {
          "name": "Generate Calendar Days (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year\": 2025,\n  \"month\": 5,\n  \"date_format\": \"AD\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/generate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "generate"]
            },
            "description": "Generates calendar days for a specific month"
          }
        },
        {
          "name": "Get Calendar Days for Month (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/month?year=2025&month=5&date_format=AD",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "month"],
              "query": [
                {
                  "key": "year",
                  "value": "2025"
                },
                {
                  "key": "month",
                  "value": "5"
                },
                {
                  "key": "date_format",
                  "value": "AD"
                }
              ]
            },
            "description": "Retrieves all calendar days for a specific month with their day types"
          }
        },
        {
          "name": "Get Available Day Types (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/day-types/available",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "day-types", "available"]
            },
            "description": "Retrieves all available day types/classifications that can be assigned"
          }
        },
        {
          "name": "Manual Assign Day Types (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year\": 2025,\n  \"month\": 5,\n  \"date_format\": \"AD\",\n  \"assignments\": [\n    {\n      \"day_number\": 1,\n      \"day_type_id\": 2\n    },\n    {\n      \"day_number\": 2,\n      \"day_type_id\": 3\n    },\n    {\n      \"day_number\": 10,\n      \"day_type_id\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/manual-assign",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "manual-assign"]
            },
            "description": "Manually assign day types to calendar days by day number - EASY FOR USERS!"
          }
        },
        {
          "name": "Assign Day Type to Specific Day (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"day_type_id\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/15/assign-type",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "15", "assign-type"]
            },
            "description": "Assigns a day type to a specific calendar day record"
          }
        },
        {
          "name": "Bulk Assign Day Types (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"calendar_day_ids\": [1, 2, 3, 4, 5],\n  \"day_type_id\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/calendar-days/bulk-assign",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "calendar-days", "bulk-assign"]
            },
            "description": "Assigns the same day type to multiple calendar days"
          }
        },
        {
          "name": "Assign Day Type by Weekday (POST)",
          "request": {
            "method": "POST",
