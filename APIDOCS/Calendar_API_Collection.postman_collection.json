    {
      "name": "Year API",
      "description": "CRUD operations for managing academic/calendar years",
      "item": [
        {
          "name": "Create Year (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year_label_AD\": \"2025-2026\",\n  \"year_label_BS\": \"2081-2082\",\n  \"start_date_AD\": \"2025-04-01\",\n  \"end_date_AD\": \"2026-03-31\",\n  \"start_date_BS\": \"2081-01-01\",\n  \"end_date_BS\": \"2082-12-30\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/year/uploadyear",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "year", "uploadyear"]
            },
            "description": "Creates a new year entry. Required: year_label_AD, year_label_BS, start_date_AD, end_date_AD, start_date_BS, end_date_BS"
          }
        },
        {
          "name": "Get All Years (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/year/getyear",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "year", "getyear"]
            },
            "description": "Retrieves all years from the system"
          }
        },
        {
          "name": "Get Year by ID (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/year/getyear/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "year", "getyear", "1"]
            },
            "description": "Retrieves a specific year by its ID"
          }
        },
        {
          "name": "Update Year (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year_label_AD\": \"2025-2026 Updated\",\n  \"year_label_BS\": \"2081-2082 Updated\",\n  \"start_date_AD\": \"2025-04-01\",\n  \"end_date_AD\": \"2026-03-31\",\n  \"start_date_BS\": \"2081-01-01\",\n  \"end_date_BS\": \"2082-12-30\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/v1/year/updateyear/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "year", "updateyear", "1"]
            },
            "description": "Updates year entry with: year_label_AD, year_label_BS, start_date_AD, end_date_AD, start_date_BS, end_date_BS"
          }
        },
        {
          "name": "Delete Year (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/v1/year/deleteyear/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["v1", "year", "deleteyear", "1"]
            },
            "description": "Deletes a year from the system"
          }
        }
      ]
    },
